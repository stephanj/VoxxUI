{
    "name": "voxx-ui",
    "version": "21.1.9",
    "author": "PrimeTek Informatics",
    "description": "VoxxUI is an open source UI component library for Angular — a lean fork of PrimeNG maintained for the cfp.dev platform.",
    "homepage": "https://github.com/stephanj/VoxxUI",
    "license": "SEE LICENSE IN LICENSE.md",
    "repository": {
        "type": "git",
        "url": "https://github.com/stephanj/VoxxUI.git",
        "directory": "packages/primeng"
    },
    "bugs": {
        "url": "https://github.com/stephanj/VoxxUI/issues"
    },
    "keywords": [
        "voxx-ui",
        "angular",
        "ui library",
        "component library",
        "primeng fork"
    ],
    "publishConfig": {
        "directory": "dist",
        "linkDirectory": false,
        "access": "public"
    },
    "scripts": {
        "build": "cross-env NODE_ENV=production INPUT_DIR=src/ OUTPUT_DIR=dist/ pnpm run build:package",
        "build:package": "pnpm run build:prebuild && ng build voxx-ui && pnpm run build:postbuild",
        "build:prebuild": "node ./scripts/prebuild.mjs",
        "build:postbuild": "node ./scripts/postbuild.mjs",
        "dev:link": "pnpm link --global && npm link",
        "lint": "ng lint",
        "test:unit": "ng test voxx-ui --watch=false --browsers=ChromeHeadless",
        "test:unit:watch": "ng test voxx-ui",
        "test:unit:coverage": "ng test voxx-ui --coverage"
    },
    "devDependencies": {
        "karma": "~6.4.4",
        "karma-chrome-launcher": "~3.2.0",
        "karma-coverage": "~2.2.1",
        "karma-jasmine": "~5.1.0",
        "karma-jasmine-html-reporter": "~2.1.0",
        "tslib": "^2.8.1"
    },
    "peerDependencies": {
        "@angular/cdk": "catalog:angular21",
        "@angular/common": "catalog:angular21",
        "@angular/core": "catalog:angular21",
        "@angular/forms": "catalog:angular21",
        "@angular/router": "catalog:angular21",
        "@angular/platform-browser": "catalog:angular21",
        "rxjs": "^6.0.0 || ^7.8.1"
    },
    "dependencies": {
        "@primeuix/styled": "catalog:",
        "@primeuix/utils": "catalog:",
        "@primeuix/styles": "catalog:",
        "@primeuix/motion": "catalog:"
    }
}
