{
    "name": "voxx-ui",
    "version": "22.0.0",
    "author": "Stephan Janssen",
    "description": "VoxxUI is an open source UI component library for Angular — a lean fork of PrimeNG maintained for the cfp.dev platform.",
    "homepage": "https://github.com/stephanj/VoxxUI",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/stephanj/VoxxUI.git",
        "directory": "packages/primeng"
    },
    "bugs": {
        "url": "https://github.com/stephanj/VoxxUI/issues"
    },
    "keywords": [
        "voxx-ui",
        "angular",
        "ui library",
        "component library",
        "primeng fork"
    ],
    "publishConfig": {
        "directory": "dist",
        "linkDirectory": false,
        "access": "public"
    },
    "scripts": {
        "build": "cross-env NODE_ENV=production INPUT_DIR=src/ OUTPUT_DIR=dist/ pnpm run build:package",
        "build:package": "pnpm run build:prebuild && ng build voxx-ui && pnpm run build:postbuild",
        "build:prebuild": "node ./scripts/prebuild.mjs",
        "build:postbuild": "node ./scripts/postbuild.mjs",
        "dev:link": "pnpm link --global && npm link",
        "lint": "ng lint",
        "test:unit": "ng test voxx-ui --watch=false",
        "test:unit:watch": "ng test voxx-ui --watch",
        "test:unit:coverage": "ng test voxx-ui --watch=false --coverage"
    },
    "devDependencies": {
        "@vitest/browser-playwright": "^4.1.10",
        "@vitest/coverage-v8": "^4.1.10",
        "jsdom": "^29.1.1",
        "playwright": "^1.56.0",
        "tslib": "^2.8.1",
        "vitest": "^4.1.10"
    },
    "peerDependencies": {
        "@angular/aria": "catalog:angular22",
        "@angular/cdk": "catalog:angular22",
        "@angular/common": "catalog:angular22",
        "@angular/core": "catalog:angular22",
        "@angular/forms": "catalog:angular22",
        "@angular/router": "catalog:angular22",
        "@angular/platform-browser": "catalog:angular22",
        "rxjs": "^6.0.0 || ^7.8.1"
    },
    "dependencies": {
        "@primeuix/styled": "catalog:",
        "@primeuix/utils": "catalog:",
        "@primeuix/styles": "catalog:",
        "@primeuix/motion": "catalog:"
    }
}
