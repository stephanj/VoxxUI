{
    // Strict-template verification config (#14): the whole library except src/table
    // (deferred to #19) must compile with strictTemplates.
    // Usage: ngc -p tsconfig.strictcheck.json --noEmit
    "extends": "./tsconfig.json",
    "include": ["src/**/*.ts"],
    "exclude": ["node_modules", "dist", "**/*.spec.ts", "src/table/**"],
    "angularCompilerOptions": {
        "disableTypeScriptVersionCheck": true,
        "fullTemplateTypeCheck": true,
        "annotateForClosureCompiler": false,
        "strictTemplates": true,
        "strictMetadataEmit": true,
        "skipTemplateCodegen": true,
        "enableI18nLegacyMessageIdFormat": false,
        "strictInjectionParameters": true,
        "strictInputAccessModifiers": true,
        "flatModuleOutFile": "primeng.js",
        "flatModuleId": "voxx-ui",
        "compilationMode": "partial"
    }
}
